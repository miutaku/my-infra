#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
FAILED=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      changed_files=$(git diff --name-only "$base" "$local_sha" 2>/dev/null || true)
    else
      changed_files=$(git ls-tree -r --name-only "$local_sha" 2>/dev/null || true)
    fi
  else
    changed_files=$(git diff --name-only "$remote_sha" "$local_sha")
  fi

  if echo "$changed_files" | grep -q "^ansible/ix2215/"; then
    echo ">>> ansible-lint (ansible/ix2215)"
    if ! (cd "$REPO_ROOT/ansible/ix2215" && pipenv run ansible-lint site.yml); then
      echo "FAILED: ansible-lint"
      FAILED=1
    fi
  fi

  if echo "$changed_files" | grep -q "^packer/ubuntu-26-04/"; then
    echo ">>> packer validate (ubuntu-26-04)"
    if ! (cd "$REPO_ROOT/packer/ubuntu-26-04" && \
      packer init . && \
      packer validate \
        -var "proxmox_token_id=ci" \
        -var "proxmox_token_secret=ci" \
        -var "ssh_password=ci" \
        -var 'ssh_password_hash=$6$ci' \
        .); then
      echo "FAILED: packer validate (ubuntu-26-04)"
      FAILED=1
    fi
  fi

  if echo "$changed_files" | grep -q "^packer/truenas-scale/"; then
    echo ">>> packer validate (truenas-scale)"
    if ! (cd "$REPO_ROOT/packer/truenas-scale" && \
      packer init . && \
      packer validate \
        -var "proxmox_token_id=ci" \
        -var "proxmox_token_secret=ci" \
        -var "admin_password=ci" \
        .); then
      echo "FAILED: packer validate (truenas-scale)"
      FAILED=1
    fi
  fi
done

exit $FAILED
