# Managed by Ansible (ansible/nut). Do not edit by hand.
# primary: USB 接続 UPS のドライバホスト側 upsmon(localhost)。FSD 発行権限あり。
[{{ nut_user_primary }}]
    password = {{ nut_monitor_password }}
    upsmon primary

# secondary: この UPS で給電されるホストの upsmon(LAN 越し)。監視のみ。
[{{ nut_user_secondary }}]
    password = {{ nut_monitor_password }}
    upsmon secondary

# admin: 手動管理用。バッテリーテストや停電ドリルでの手動 killpower(load.off.delay)など、
# インスタントコマンド全般を許可する。パスワードは監視用と同じ共有シークレットを流用。
#   例: upscmd -u {{ nut_user_admin }} -p <pw> {{ nut_ups.name }}@localhost test.battery.start.deep
[{{ nut_user_admin }}]
    password = {{ nut_monitor_password }}
    actions = SET
    instcmds = ALL
