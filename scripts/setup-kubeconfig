#!/usr/bin/env bash
# 各クラスタから kubeconfig を取得して ~/.kube/config に統合する
# Usage:
#   setup-kubeconfig             # RKE2 + OKE 両方
#   setup-kubeconfig --rke2-only
#   setup-kubeconfig --oke-only
set -euo pipefail

export OCI_CLI_SUPPRESS_FILE_PERMISSIONS_WARNING=True
export SUPPRESS_LABEL_WARNING=True

KUBE_DIR="$HOME/.kube"
RKE2_YAML="$KUBE_DIR/rke2.yaml"
OKE_YAML="$KUBE_DIR/oke.yaml"
MERGED="$KUBE_DIR/config"

# RKE2: primary server の IP (master-01)
RKE2_HOST="${RKE2_HOST:-192.168.20.126}"
RKE2_USER="${RKE2_USER:-miutaku}"
# RKE2 の kubeconfig は 127.0.0.1:6443 → LB VIP に書き換える
RKE2_LB_VIP="${RKE2_LB_VIP:-192.168.20.227}"

# OKE: クラスタ OCID (terraform apply 後に固定)
OKE_CLUSTER_OCID="${OKE_CLUSTER_OCID:-ocid1.cluster.oc1.ap-tokyo-1.aaaaaaaaxroxdjngbtuj63b3rqlczoidrjvu2cnlpqv7euzi6cl7a5hbbwnq}"
OCI_REGION="${OCI_REGION:-ap-tokyo-1}"

fetch_rke2() {
  echo "[rke2] $RKE2_USER@$RKE2_HOST から kubeconfig を取得..."
  # /etc/rancher/rke2/rke2.yaml は root 所有のため sudo cat で取得
  ssh "$RKE2_USER@$RKE2_HOST" "sudo cat /etc/rancher/rke2/rke2.yaml" > "$RKE2_YAML"
  chmod 600 "$RKE2_YAML"

  # server が 127.0.0.1 のままだと外部から接続できないため LB VIP に書き換え
  sed -i "s|server: https://127.0.0.1:6443|server: https://${RKE2_LB_VIP}:6443|" "$RKE2_YAML"

  local current_ctx
  current_ctx=$(kubectl --kubeconfig "$RKE2_YAML" config current-context)
  if [[ "$current_ctx" != "rke2-pve" ]]; then
    kubectl --kubeconfig "$RKE2_YAML" config rename-context "$current_ctx" rke2-pve
  fi
  echo "[rke2] 完了 (server: https://${RKE2_LB_VIP}:6443, context: rke2-pve)"
}

fetch_oke() {
  echo "[oke] OKE kubeconfig を取得..."
  # 既存ファイルがあると merge されてコンテキスト名が衝突するため先に削除
  rm -f "$OKE_YAML"
  oci ce cluster create-kubeconfig \
    --cluster-id "$OKE_CLUSTER_OCID" \
    --file "$OKE_YAML" \
    --region "$OCI_REGION" \
    --kube-endpoint PUBLIC_ENDPOINT
  chmod 600 "$OKE_YAML"

  local current_ctx
  current_ctx=$(kubectl --kubeconfig "$OKE_YAML" config current-context)
  if [[ "$current_ctx" != "oke-cloud" ]]; then
    kubectl --kubeconfig "$OKE_YAML" config rename-context "$current_ctx" oke-cloud
  fi
  echo "[oke] 完了 (context: oke-cloud)"
}

merge() {
  local configs=()
  [[ -f "$RKE2_YAML" ]] && configs+=("$RKE2_YAML")
  [[ -f "$OKE_YAML"  ]] && configs+=("$OKE_YAML")

  if [[ ${#configs[@]} -eq 0 ]]; then
    echo "統合対象の kubeconfig がありません。" >&2
    exit 1
  fi

  local joined
  joined=$(IFS=: ; echo "${configs[*]}")
  KUBECONFIG="$joined" kubectl config view --flatten > "$MERGED"
  chmod 600 "$MERGED"

  local contexts
  contexts=$(kubectl --kubeconfig "$MERGED" config get-contexts -o name | tr '\n' ' ')
  echo "[merge] ~/.kube/config 更新完了 (contexts: $contexts)"
}

case "${1:-all}" in
  --rke2-only) fetch_rke2 ;;
  --oke-only)  fetch_oke  ;;
  all|*)
    fetch_rke2
    fetch_oke
    ;;
esac

merge
