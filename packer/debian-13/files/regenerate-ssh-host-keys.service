[Unit]
Description=Regenerate SSH host keys if missing (post-clone)
# Template build removes /etc/ssh/ssh_host_* so each clone gets unique keys.
# On Debian nothing regenerates them on first boot (cloud-init can be delayed
# or stuck), which makes sshd fail to start. Generate them before ssh starts.
Before=ssh.service
ConditionPathExists=!/etc/ssh/ssh_host_ed25519_key

[Service]
Type=oneshot
ExecStart=/usr/sbin/ssh-keygen -A
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
